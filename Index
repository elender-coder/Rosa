<html lang="es">
<head>
<meta charset="UTF-8">
<title>Netflix Clone</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family:Arial;
}

body{
  background:#111;
  color:white;
}

/* NAV */
.navbar{
  position:fixed;
  top:0;
  width:100%;
  padding:20px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  background:linear-gradient(to bottom, black, transparent);
  z-index:10;
}

.logo{
  color:red;
}

.nav-right{
  display:flex;
  align-items:center;
}

.nav-right input{
  padding:8px;
  border:none;
  outline:none;
  border-radius:4px;
}

/* HERO */
.hero{
  height:60vh;
  background:url("https://picsum.photos/1200/600") center/cover no-repeat;
  display:flex;
  align-items:flex-end;
  padding:50px;
}

.hero h2{
  font-size:40px;
}

/* ROW */
.row{
  margin-top:80px;
  padding:20px;
}

.row h3{
  margin-bottom:10px;
}

.row-posters{
  display:flex;
  overflow-x:auto;
}

.card{
  margin-right:10px;
  text-align:center;
}

.card img{
  width:150px;
  border-radius:5px;
  transition:0.3s;
  cursor:pointer;
}

.card img:hover{
  transform:scale(1.1);
}

.card p{
  margin-top:5px;
  font-size:14px;
}

/* SEARCH RESULTS */
#results{
  padding:20px;
  margin-top:80px;
  display:none;
}

.grid{
  display:flex;
  flex-wrap:wrap;
}

.grid .card{
  width:150px;
  margin:10px;
}
</style>

</head>
<body>

<header class="navbar">
  <h1 class="logo">NETFLIX</h1>
  <div class="nav-right">
    <input type="text" id="search" placeholder="Buscar...">
  </div>
</header>

<section class="hero">
  <h2>Película Destacada</h2>
</section>

<!-- RESULTADOS -->
<section id="results">
  <h3>Resultados</h3>
  <div class="grid" id="resultsGrid"></div>
</section>

<!-- FILAS -->
<section class="row">
  <h3>Populares</h3>
  <div class="row-posters" id="popular"></div>
</section>

<section class="row">
  <h3>Tendencias</h3>
  <div class="row-posters" id="trending"></div>
</section>

<script>
// DATA FAKE
const movies = [
  {title:"Stranger Things", img:"https://picsum.photos/200/300?1"},
  {title:"Breaking Bad", img:"https://picsum.photos/200/300?2"},
  {title:"The Witcher", img:"https://picsum.photos/200/300?3"},
  {title:"Dark", img:"https://picsum.photos/200/300?4"},
  {title:"Money Heist", img:"https://picsum.photos/200/300?5"},
  {title:"Squid Game", img:"https://picsum.photos/200/300?6"},
  {title:"Wednesday", img:"https://picsum.photos/200/300?7"},
  {title:"Narcos", img:"https://picsum.photos/200/300?8"},
];

// RENDER
function render(id, data){
  const container = document.getElementById(id);
  container.innerHTML = "";
  data.forEach(m => {
    container.innerHTML += `
      <div class="card">
        <img src="${m.img}">
        <p>${m.title}</p>
      </div>
    `;
  });
}

render("popular", movies);
render("trending", movies.reverse());

// SEARCH
const search = document.getElementById("search");
const results = document.getElementById("results");
const resultsGrid = document.getElementById("resultsGrid");

search.addEventListener("input", () => {
  const value = search.value.toLowerCase();

  if(value === ""){
    results.style.display = "none";
    return;
  }

  const filtered = movies.filter(m =>
    m.title.toLowerCase().includes(value)
  );

  results.style.display = "block";
  resultsGrid.innerHTML = "";

  filtered.forEach(m => {
    resultsGrid.innerHTML += `
      <div class="card">
        <img src="${m.img}">
        <p>${m.title}</p>
      </div>
    `;
  });
});
</script>

</body>
</html>
